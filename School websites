<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Bright Future International School</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family: Arial, sans-serif;
}

body{
    background:#f5f9ff;
    color:#333;
}

/* Navbar */
nav{
    background:#0056b3;
    color:white;
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:15px 8%;
    position:sticky;
    top:0;
    z-index:1000;
}

.logo{
    font-size:24px;
    font-weight:bold;
}

nav ul{
    list-style:none;
    display:flex;
}

nav ul li{
    margin-left:20px;
}

nav ul li a{
    color:white;
    text-decoration:none;
    font-weight:bold;
}

nav ul li a:hover{
    color:#dbe9ff;
}

/* Hero Section */
.hero{
    height:90vh;
    background:url('https://images.unsplash.com/photo-1509062522246-3755977927d7?w=1200')
    center/cover no-repeat;
    display:flex;
    justify-content:center;
    align-items:center;
    text-align:center;
    color:white;
    position:relative;
}

.hero::before{
    content:'';
    position:absolute;
    top:0;
    left:0;
    width:100%;
    height:100%;
    background:rgba(0,0,0,0.5);
}

.hero-content{
    position:relative;
    z-index:2;
}

.hero h1{
    font-size:3rem;
    margin-bottom:15px;
}

.hero p{
    font-size:1.2rem;
}

/* Sections */
section{
    padding:70px 10%;
}

.section-title{
    text-align:center;
    color:#0056b3;
    margin-bottom:40px;
    font-size:2rem;
}

/* About */
.about{
    background:white;
    border-radius:10px;
    padding:30px;
    box-shadow:0 5px 15px rgba(0,0,0,0.1);
}

.about p{
    line-height:1.8;
}

/* Facilities */
.cards{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
    gap:20px;
}

.card{
    background:white;
    padding:25px;
    border-radius:12px;
    text-align:center;
    box-shadow:0 4px 10px rgba(0,0,0,0.1);
    transition:0.3s;
}

.card:hover{
    transform:translateY(-5px);
}

.card h3{
    color:#0056b3;
    margin-bottom:10px;
}

/* Footer */
footer{
    background:#0056b3;
    color:white;
    text-align:center;
    padding:30px;
}

footer p{
    margin:10px 0;
}

/* Mobile */
@media(max-width:768px){

    nav{
        flex-direction:column;
    }

    nav ul{
        margin-top:10px;
        flex-wrap:wrap;
        justify-content:center;
    }

    .hero h1{
        font-size:2rem;
    }

    .hero p{
        font-size:1rem;
    }
}
</style>
</head>

<body>

<!-- Navbar -->
<nav>
    <div class="logo">🎓 Bright Future International School</div>

    <ul>
        <li><a href="#home">Home</a></li>
        <li><a href="#about">About</a></li>
        <li><a href="#facilities">Facilities</a></li>
        <li><a href="#contact">Contact</a></li>
    </ul>
</nav>

<!-- Hero Section -->
<section class="hero" id="home">
    <div class="hero-content">
        <h1>Welcome to Bright Future International School</h1>
        <p>Inspiring Excellence, Building Future Leaders</p>
    </div>
</section>

<!-- About Us -->
<section id="about">
    <h2 class="section-title">About Us</h2>

    <div class="about">
        <h3>Principal's Message</h3>
        <br>
        <p>
            Welcome to Bright Future International School.
            Our mission is to provide quality education,
            encourage creativity, and help every student
            achieve academic excellence. We believe in
            developing confident, responsible, and future-ready
            learners who can contribute positively to society.
        </p>
    </div>
</section>

<!-- Facilities -->
<section id="facilities">
    <h2 class="section-title">Our Facilities</h2>

    <div class="cards">

        <div class="card">
            <h3>💻 Computer Lab</h3>
            <p>
                Modern computers with high-speed internet
                for practical learning and digital education.
            </p>
        </div>

        <div class="card">
            <h3>⚽ Sports</h3>
            <p>
                Excellent sports facilities to encourage
                physical fitness and teamwork.
            </p>
        </div>

        <div class="card">
            <h3>📚 Library</h3>
            <p>
                Well-stocked library with educational books,
                magazines and reference materials.
            </p>
        </div>

    </div>
</section>

<!-- Footer -->
<footer id="contact">
    <h2>Contact Us</h2>

    <p>📞 Phone: +91 98765 43210</p>

    <p>
        📍 Address: Bright Future International School,
        Main Road, Your City, India
    </p>

    <p>&copy; 2026 Bright Future International School. All Rights Reserved.</p>
</footer>

<script>

// Smooth Scroll
document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function(e) {
        e.preventDefault();

        document.querySelector(this.getAttribute('href'))
        .scrollIntoView({
            behavior: 'smooth'
        });
    });
});

</script>

</body>
</html>
